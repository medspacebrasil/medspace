# Database (Supabase)
DATABASE_URL="postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres"

# Auth.js
AUTH_SECRET="gerar-com-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="xxxx"
SUPABASE_SERVICE_ROLE_KEY="xxxx"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_WHATSAPP_DEFAULT_MESSAGE="Ola, vi seu anuncio no MedSpace e tenho interesse!"

# Rate limiting (Upstash Redis) — protege login/cadastro contra brute-force.
# Crie um banco gratuito em https://console.upstash.com e copie as credenciais REST.
# Se ficar em branco, o rate limiting fica DESATIVADO (apenas para dev/pre-lancamento).
UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="xxxx"
